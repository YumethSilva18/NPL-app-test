// Prisma Schema for NPL Predictor Backend
// This is your database schema definition

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User Management
model User {
  id            String   @id @default(uuid())
  email         String   @unique
  password      String
  firstName     String?
  lastName      String?
  role          UserRole @default(ANALYST)
  isActive      Boolean  @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  predictions   Prediction[]
  auditLogs     AuditLog[]
  refreshTokens RefreshToken[]
  
  @@map("users")
  @@index([email])
  @@index([role])
}

enum UserRole {
  ADMIN
  MANAGER
  ANALYST
  VIEWER
}

// Refresh Tokens for JWT
model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  revokedAt DateTime?
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("refresh_tokens")
  @@index([userId])
  @@index([token])
  @@index([expiresAt])
}

// NPL Prediction Records
model Prediction {
  id                    String       @id @default(uuid())
  customerId            String
  
  // Input Features
  creditScore           Int
  income                Decimal      @db.Decimal(12, 2)
  loanAmount            Decimal      @db.Decimal(12, 2)
  loanTerm              Int
  employmentYears       Int
  debtToIncomeRatio     Decimal      @db.Decimal(5, 4)
  loanToValueRatio      Decimal      @db.Decimal(5, 4)
  interestRate          Decimal      @db.Decimal(5, 2)
  paymentHistoryScore   Int
  previousDefaults      Int
  age                   Int
  collateralValue       Decimal      @db.Decimal(12, 2)
  accountAge            Int
  utilizationRatio      Decimal      @db.Decimal(5, 4)
  monthlyInstallment    Decimal      @db.Decimal(12, 2)
  
  // Output Results
  nplProbability        Decimal      @db.Decimal(5, 4)
  riskLevel             RiskLevel
  confidence            Decimal      @db.Decimal(5, 4)
  recommendation        String       @db.Text
  decisionHint          DecisionHint
  
  // Model Metadata
  modelVersion          String       @default("1.0.0")
  modelName             String       @default("npl-classifier-v1")
  processingTimeMs      Int?
  
  // Score Breakdown (JSON for flexibility)
  scoreBreakdown        Json?
  
  // Audit
  userId                String?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
  
  user                  User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  @@map("predictions")
  @@index([customerId])
  @@index([riskLevel])
  @@index([decisionHint])
  @@index([createdAt])
  @@index([userId])
}

enum RiskLevel {
  Low
  Medium
  High
}

enum DecisionHint {
  Approve
  Review
  Escalate
  Decline
}

// System Settings
model Setting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     Json
  category  String   @default("general")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@map("settings")
  @@index([key])
  @@index([category])
}

// ML Model Registry
model MLModel {
  id              String        @id @default(uuid())
  name            String        @unique
  version         String
  description     String?
  modelType       String        // e.g., "classification", "regression"
  framework       String        // e.g., "tensorflow", "pytorch", "scikit-learn"
  inputFeatures   Json          // Feature schema
  outputSchema    Json          // Output schema
  metrics         Json?         // Accuracy, F1, etc.
  isActive        Boolean       @default(false)
  isProduction    Boolean       @default(false)
  serviceUrl      String?
  configParams    Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  activatedAt     DateTime?
  deactivatedAt   DateTime?
  
  @@map("ml_models")
  @@index([name, version])
  @@index([isActive])
  @@index([isProduction])
}

// Audit Log for security and compliance
model AuditLog {
  id          String   @id @default(uuid())
  userId      String?
  action      String
  resource    String
  resourceId  String?
  method      String
  path        String
  statusCode  Int
  ipAddress   String?
  userAgent   String?
  requestId   String?
  metadata    Json?
  createdAt   DateTime @default(now())
  
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  @@map("audit_logs")
  @@index([userId])
  @@index([action])
  @@index([resource])
  @@index([createdAt])
  @@index([requestId])
}

// System Health Metrics
model HealthMetric {
  id              String   @id @default(uuid())
  timestamp       DateTime @default(now())
  serviceStatus   String
  modelLoaded     Boolean
  responseTimeMs  Int
  cpuUsage        Decimal? @db.Decimal(5, 2)
  memoryUsage     Decimal? @db.Decimal(5, 2)
  activeRequests  Int?
  errorRate       Decimal? @db.Decimal(5, 4)
  
  @@map("health_metrics")
  @@index([timestamp])
}
